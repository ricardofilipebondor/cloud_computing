# Shared
APP_MODE=local
JWT_SECRET=dev-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streamsync

# Queue mode: local | gcp
QUEUE_PROVIDER=local
GCP_PROJECT_ID=
GCP_PUBSUB_TOPIC=streamsync-jobs
GCP_PUBSUB_SUBSCRIPTION=streamsync-jobs-sub

# Storage mode: local | gcs
STORAGE_PROVIDER=local
GCS_BUCKET_NAME=

# AI providers
OPENAI_API_KEY=
DEEPL_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# Worker
WORKER_POLL_INTERVAL_MS=2000
WORKER_TEMP_DIR=workers/python/tmp
# Optional: path to ffmpeg.exe folder if not in PATH (Windows example)
# FFMPEG_LOCATION=C:\ffmpeg\bin
